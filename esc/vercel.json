<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<meta name="theme-color" content="#060610"/>
<title>🎤 Karaoke Party — Audiência</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#060610;--surf:#0d0d1f;--card:#12122a;--bdr:#1e1e44;
  --pink:#ff2d78;--cyan:#00f5ff;--yel:#ffdd00;--grn:#00ff9d;--purple:#bf5fff;
  --white:#f0f0ff;--dim:#505075;
  --fh:'Bebas Neue',sans-serif;--fb:'Space Mono',monospace;
  --safe-b:env(safe-area-inset-bottom,0px);
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--white);font-family:var(--fb);font-size:13px;min-height:100vh;overflow-x:hidden;-webkit-tap-highlight-color:transparent}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:9000;background:repeating-linear-gradient(0deg,transparent 0,transparent 3px,rgba(0,0,0,.04) 3px,rgba(0,0,0,.04) 4px)}

.screen{display:none;min-height:100vh}
.screen.active{display:flex}

/* ── JOIN ── */
#join{flex-direction:column;align-items:center;justify-content:center;padding:1.5rem;position:relative;overflow:hidden;gap:0}
.jbg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 20% 80%,rgba(191,95,255,.15),transparent 55%),radial-gradient(ellipse 60% 50% at 80% 20%,rgba(0,245,255,.1),transparent 50%),radial-gradient(ellipse 100% 60% at 50% 100%,rgba(255,45,120,.12),transparent 55%)}
.jgrid{position:absolute;inset:0;background-image:linear-gradient(var(--bdr) 1px,transparent 1px),linear-gradient(90deg,var(--bdr) 1px,transparent 1px);background-size:60px 60px;opacity:.15;mask-image:radial-gradient(ellipse at 50% 50%,black 40%,transparent 75%)}
.join-panel{position:relative;z-index:10;background:var(--card);border:1px solid var(--bdr);border-radius:20px;padding:2rem;width:100%;max-width:380px;display:flex;flex-direction:column;gap:0}
.aud-chip{display:inline-flex;align-items:center;gap:.4rem;background:rgba(0,245,255,.08);border:1px solid var(--cyan);border-radius:50px;padding:.2rem .85rem;font-size:.54rem;letter-spacing:.22em;text-transform:uppercase;color:var(--cyan);margin-bottom:1.2rem;align-self:flex-start}
.j-logo{font-family:var(--fh);font-size:3.5rem;color:var(--white);letter-spacing:.02em;line-height:.9;text-shadow:0 0 40px rgba(255,45,120,.3)}
.j-logo em{font-style:normal;color:var(--pink)}
.j-sub{font-size:.68rem;color:var(--dim);line-height:1.7;margin:.8rem 0 1.5rem}
.field{display:flex;flex-direction:column;gap:.35rem;margin-bottom:.9rem}
.field label{font-size:.57rem;letter-spacing:.22em;text-transform:uppercase;color:var(--dim)}
input[type=text]{background:var(--surf);border:1.5px solid var(--bdr);border-radius:8px;color:var(--white);font-family:var(--fb);font-size:.92rem;padding:.7rem 1rem;width:100%;outline:none;transition:border-color .2s;-webkit-appearance:none}
input[type=text]:focus{border-color:var(--cyan)}
input::placeholder{color:var(--dim)}
.err{color:#ff6b6b;font-size:.7rem;margin-top:.3rem;min-height:1em}

/* ── BUTTONS ── */
.btn{font-family:var(--fb);font-size:.74rem;padding:.65rem 1.4rem;border:none;border-radius:8px;cursor:pointer;letter-spacing:.08em;text-transform:uppercase;transition:all .15s;position:relative;overflow:hidden;touch-action:manipulation;font-weight:700}
.btn::after{content:'';position:absolute;inset:0;background:#fff;opacity:0;transition:.1s}
.btn:active::after{opacity:.12}
.btn-cyan{background:var(--cyan);color:#060610;box-shadow:0 0 20px rgba(0,245,255,.25)}
.btn-cyan:active{transform:scale(.97)}
.btn-pink{background:var(--pink);color:#fff}
.btn-ghost{background:transparent;color:var(--dim);border:1px solid var(--bdr)}
.btn-danger{background:transparent;color:#ff5555;border:1px solid #ff5555}
.btn-sm{padding:.4rem .85rem;font-size:.67rem}
.btn-block{width:100%}

/* ── AUDIENCE ROOM ── */
#aud-room{flex-direction:column;min-height:100vh}
#aud-room.active{display:flex}

/* ── TOPBAR ── */
.aud-topbar{background:var(--surf);border-bottom:1px solid var(--bdr);padding:.55rem 1rem;display:flex;align-items:center;gap:.7rem;flex-shrink:0;position:sticky;top:0;z-index:500}
.at-chip{display:flex;align-items:center;gap:.35rem;background:rgba(0,245,255,.08);border:1px solid var(--cyan);border-radius:50px;padding:.18rem .7rem}
.at-dot{width:7px;height:7px;border-radius:50%;background:var(--pink);animation:blink 1.2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.at-live{font-size:.54rem;letter-spacing:.2em;text-transform:uppercase;color:var(--pink)}
.at-room{font-family:var(--fh);font-size:1.1rem;color:var(--white);letter-spacing:.05em;flex:1}
.at-streamer{font-size:.63rem;color:var(--cyan)}
.at-aud-badge{font-size:.55rem;letter-spacing:.15em;text-transform:uppercase;color:var(--purple);background:rgba(191,95,255,.1);border:1px solid var(--purple);border-radius:50px;padding:.18rem .65rem}

/* ── MAIN SCROLL ── */
.aud-scroll{flex:1;overflow-y:auto;padding:.9rem;display:flex;flex-direction:column;gap:.8rem;padding-bottom:calc(64px + var(--safe-b) + .5rem)}

/* ── NOW PLAYING ── */
.np-card{background:var(--card);border:1px solid var(--pink);border-radius:14px;padding:1.1rem;box-shadow:0 0 30px rgba(255,45,120,.1)}
.np-header{display:flex;align-items:center;gap:.6rem;margin-bottom:.5rem;flex-wrap:wrap}
.np-badge{background:var(--pink);color:#fff;font-size:.53rem;letter-spacing:.18em;text-transform:uppercase;padding:.16rem .5rem;border-radius:4px;animation:pulse-badge 2s ease-in-out infinite}
@keyframes pulse-badge{0%,100%{box-shadow:0 0 0 0 rgba(255,45,120,.5)}70%{box-shadow:0 0 0 6px rgba(255,45,120,0)}}
.np-who{color:var(--cyan);font-size:.73rem}
.np-title{font-family:var(--fh);font-size:1.8rem;color:var(--white);display:block;line-height:1}
.np-artist{font-size:.7rem;color:var(--dim);display:block;margin-top:.1rem}
.yt-wrap{margin:.7rem 0;border-radius:10px;overflow:hidden;aspect-ratio:16/9;background:#000;position:relative}
.yt-wrap>div:first-child{width:100%;height:100%}
.sync-overlay{position:absolute;inset:0;background:rgba(6,6,16,.9);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.6rem;font-size:.78rem;color:var(--dim)}
.sync-overlay.gone{display:none}
.sdot{width:9px;height:9px;border-radius:50%;background:var(--cyan);animation:sdot 1.2s ease-in-out infinite}
@keyframes sdot{0%,100%{opacity:.2;transform:scale(.8)}50%{opacity:1;transform:scale(1.2)}}
.pbstatus{background:var(--surf);border:1px solid var(--bdr);border-radius:8px;padding:.45rem .8rem;display:flex;align-items:center;gap:.65rem;font-size:.7rem;color:var(--dim);margin-top:.4rem}
.pbdot{width:7px;height:7px;border-radius:50%;background:var(--dim);flex-shrink:0}
.pbdot.on{background:var(--grn);animation:blink 1s ease-in-out infinite}
.pbtbar{flex:1;height:3px;background:var(--bdr);border-radius:2px;overflow:hidden}
.pbtfill{height:100%;background:var(--pink);border-radius:2px;transition:width .5s linear}
.lbox{background:var(--surf);border-radius:10px;padding:.9rem 1.1rem;min-height:70px;max-height:45vh;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--bdr) transparent;margin-top:.5rem}
.lyric{font-size:1rem;line-height:1.8;color:var(--dim);transition:all .25s}
.lyric.active{color:var(--yel);font-size:1.2rem;text-shadow:0 0 16px rgba(255,221,0,.5);transform:translateX(6px)}
.lyric.past{color:var(--bdr);opacity:.5}
.lnone{color:var(--dim);font-style:italic;font-size:.78rem;text-align:center;padding:.8rem}
.lloader{display:flex;align-items:center;gap:.6rem;color:var(--dim);font-size:.73rem}
.spin{width:14px;height:14px;border:2px solid var(--bdr);border-top-color:var(--cyan);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.idle-box{text-align:center;padding:2.5rem 1rem;color:var(--dim)}
.idle-icon{font-size:3rem;opacity:.3;display:block;margin-bottom:.7rem}

/* ── REACTIONS ── */
.react-card{background:var(--card);border:1px solid var(--bdr);border-radius:14px;padding:1rem}
.rc-title{font-size:.54rem;letter-spacing:.2em;text-transform:uppercase;color:var(--cyan);margin-bottom:.7rem}
.react-btns{display:grid;grid-template-columns:repeat(4,1fr);gap:.4rem}
.rbtn{background:var(--surf);border:1px solid var(--bdr);border-radius:10px;padding:.6rem .5rem;font-size:1.4rem;cursor:pointer;transition:all .15s;text-align:center;line-height:1;min-height:48px;display:flex;align-items:center;justify-content:center}
.rbtn:active{transform:scale(.88);background:var(--bdr)}
.react-feed{height:48px;overflow:hidden;position:relative;margin-top:.6rem}
.react-float{position:absolute;bottom:0;font-size:1.5rem;animation:float-up 2.5s ease forwards;pointer-events:none}
@keyframes float-up{0%{opacity:1;transform:translateY(0)}100%{opacity:0;transform:translateY(-60px)}}

/* ── VOTE/SUGGEST ── */
.vote-card{background:var(--card);border:1px solid var(--purple);border-radius:14px;padding:1.1rem;box-shadow:0 0 25px rgba(191,95,255,.08)}
.vc-title{font-family:var(--fh);font-size:1.3rem;color:var(--purple);letter-spacing:.05em;margin-bottom:.3rem}
.vc-sub{font-size:.6rem;color:var(--dim);margin-bottom:.9rem}
.suggest-row{display:flex;gap:.4rem;margin-bottom:.5rem}
.suggest-row input{flex:1}
.sres{display:flex;flex-direction:column;gap:.3rem;max-height:180px;overflow-y:auto;margin-bottom:.6rem}
.ri{background:var(--surf);border:1px solid var(--bdr);border-radius:8px;padding:.5rem .75rem;display:flex;justify-content:space-between;align-items:center;gap:.5rem}
.ri:active{border-color:var(--cyan)}
.ri-info{flex:1;min-width:0}
.ri-t{font-size:.78rem;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ri-a{font-size:.62rem;color:var(--dim)}
.vote-list{display:flex;flex-direction:column;gap:.45rem}
.v-item{background:var(--surf);border:1px solid var(--bdr);border-radius:9px;padding:.6rem .8rem;display:flex;align-items:center;gap:.7rem;transition:.15s}
.v-item.voted{border-color:var(--purple);background:rgba(191,95,255,.08)}
.v-info{flex:1;min-width:0}
.v-t{font-size:.78rem;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.v-meta{font-size:.6rem;color:var(--dim)}
.v-bar-wrap{width:60px;display:flex;flex-direction:column;gap:.2rem;align-items:flex-end}
.v-bar{width:100%;height:3px;background:var(--bdr);border-radius:2px;overflow:hidden}
.v-fill{height:100%;background:var(--purple);transition:width .4s;border-radius:2px}
.v-count{font-size:.6rem;color:var(--purple);font-weight:700}
.vote-btn{background:var(--purple);color:#fff;border:none;border-radius:6px;padding:.4rem .75rem;font-size:.63rem;cursor:pointer;font-family:var(--fb);font-weight:700;white-space:nowrap;transition:.15s;letter-spacing:.04em}
.vote-btn:active{filter:brightness(1.15)}
.vote-btn.voted{background:var(--grn);color:#060610}
.v-empty{color:var(--dim);font-style:italic;font-size:.72rem;text-align:center;padding:.6rem}

/* ── CHAT ── */
.chat-card{background:var(--card);border:1px solid var(--bdr);border-radius:14px;padding:1rem}
.chat-title{font-size:.54rem;letter-spacing:.2em;text-transform:uppercase;color:var(--cyan);margin-bottom:.7rem}
.cmsgs{height:160px;overflow-y:auto;display:flex;flex-direction:column;gap:.25rem;margin-bottom:.6rem;scrollbar-width:thin;scrollbar-color:var(--bdr) transparent}
.msg{font-size:.73rem;line-height:1.4;padding:.22rem .38rem;border-radius:4px}
.msg .who{margin-right:.35rem}
.msg .who.host{color:var(--pink)}
.msg .who.aud{color:var(--purple)}
.msg .who.singer{color:var(--cyan)}
.msg.sys{color:var(--dim);font-style:italic}
.msg.mine{background:rgba(191,95,255,.07)}
.chat-row{display:flex;gap:.4rem}.chat-row input{flex:1}

/* ── BOTTOM NAV ── */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;z-index:600;background:var(--surf);border-top:1px solid var(--bdr);padding-bottom:var(--safe-b);display:grid;grid-template-columns:repeat(3,1fr)}
.bnbtn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;background:none;border:none;cursor:pointer;color:var(--dim);font-family:var(--fb);font-size:.51rem;letter-spacing:.04em;text-transform:uppercase;padding:.7rem 0;min-height:56px;position:relative;transition:color .15s;touch-action:manipulation}
.bnbtn.on{color:var(--cyan)}
.bnicon{font-size:1.15rem;line-height:1}
.bnbadge{position:absolute;top:8px;right:calc(50% - 18px);background:var(--pink);color:#fff;font-size:.5rem;font-weight:700;border-radius:50%;width:14px;height:14px;display:flex;align-items:center;justify-content:center}

/* ── TOAST ── */
#toast{position:fixed;bottom:calc(64px + var(--safe-b) + .8rem);right:.9rem;z-index:99999;background:var(--card);border:1px solid var(--cyan);color:var(--white);padding:.6rem 1.1rem;border-radius:10px;font-size:.78rem;opacity:0;pointer-events:none;transform:translateY(8px);transition:opacity .25s,transform .25s;box-shadow:0 4px 20px rgba(0,0,0,.5)}
#toast.show{opacity:1;transform:translateY(0)}

/* ── DESKTOP ── */
@media(min-width:660px){
  .bottom-nav{display:none}
  .aud-scroll{padding-bottom:.9rem}
  .react-btns{grid-template-columns:repeat(8,1fr)}
}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-thumb{background:var(--bdr);border-radius:3px}
</style>
</head>
<body>

<!-- JOIN -->
<div id="join" class="screen active">
  <div class="jbg"></div><div class="jgrid"></div>
  <div class="join-panel">
    <div class="aud-chip">👥 Audiência</div>
    <div class="j-logo">KARA<em>OKÉ</em></div>
    <p class="j-sub">Entra na stream, reage em tempo real, sugere músicas e vota nas favoritas!</p>
    <div class="field"><label>O teu nick</label><input id="aud-name" type="text" placeholder="FãNúmero1" maxlength="20" autocomplete="off"/></div>
    <div class="field"><label>Código da sala</label><input id="aud-code" type="text" placeholder="ABC123" maxlength="6" style="text-transform:uppercase;letter-spacing:.3em" autocomplete="off"/></div>
    <button class="btn btn-cyan btn-block" id="aud-submit">Entrar na Stream 🎤</button>
    <div id="aud-err" class="err"></div>
  </div>
</div>

<!-- AUDIENCE ROOM -->
<div id="aud-room" class="screen">

  <!-- Topbar -->
  <div class="aud-topbar">
    <div class="at-chip"><div class="at-dot"></div><span class="at-live">Live</span></div>
    <span class="at-room" id="at-room">---</span>
    <span class="at-streamer" id="at-streamer"></span>
    <span class="at-aud-badge">👁️ Audiência</span>
  </div>

  <!-- Scroll content -->
  <div class="aud-scroll" id="aud-scroll">

    <!-- Now Playing -->
    <div id="np-card" class="np-card" style="display:none">
      <div class="np-header"><span class="np-badge">▶ A TOCAR</span><span id="np-who" class="np-who"></span></div>
      <span id="np-title" class="np-title"></span>
      <span id="np-artist" class="np-artist"></span>
      <div class="yt-wrap" id="yt-wrap" style="display:none"><div id="ytplayer"></div><div class="sync-overlay gone" id="sync-overlay"><div class="sdot"></div><span id="sync-label">A sincronizar…</span></div></div>
      <div class="pbstatus" id="pbstatus" style="display:none"><div class="pbdot on" id="pbdot"></div><span id="pblabel">▶ A tocar</span><div class="pbtbar"><div class="pbtfill" id="pbtfill" style="width:0%"></div></div><span id="pbtime" style="font-size:.6rem;flex-shrink:0">0:00</span></div>
      <div class="lbox"><div class="lloader" id="lload" style="display:none"><div class="spin"></div>A buscar letra...</div><div id="llines"></div><div id="lnone" class="lnone" style="display:none">🎵 Letra não encontrada</div></div>
    </div>
    <div id="idle" class="idle-box"><span class="idle-icon">📺</span><p>A aguardar que o streamer comece…<br/>Enquanto isso, sugere uma música!</p></div>

    <!-- Reactions section (always visible) -->
    <div class="react-card" id="sec-react">
      <div class="rc-title">Reagir ao Vivo 🎉</div>
      <div class="react-btns">
        <button class="rbtn" onclick="sendReaction('🔥')">🔥</button>
        <button class="rbtn" onclick="sendReaction('❤️')">❤️</button>
        <button class="rbtn" onclick="sendReaction('😂')">😂</button>
        <button class="rbtn" onclick="sendReaction('👏')">👏</button>
        <button class="rbtn" onclick="sendReaction('😱')">😱</button>
        <button class="rbtn" onclick="sendReaction('🎵')">🎵</button>
        <button class="rbtn" onclick="sendReaction('💜')">💜</button>
        <button class="rbtn" onclick="sendReaction('⭐')">⭐</button>
      </div>
      <div class="react-feed" id="react-feed"></div>
    </div>

    <!-- Vote / Suggest section -->
    <div class="vote-card" id="sec-vote">
      <div class="vc-title">🗳️ Sugere &amp; Vota</div>
      <div class="vc-sub">As mais votadas entram na fila do streamer!</div>
      <div class="suggest-row"><input id="sq" type="text" placeholder="Pesquisar música para sugerir…" autocomplete="off"/><button class="btn btn-cyan btn-sm" id="suggest-btn">Sugerir</button></div>
      <div class="sres" id="sres"></div>
      <div class="vote-list" id="vote-list"><div class="v-empty">Ainda sem sugestões — sê o primeiro!</div></div>
    </div>

    <!-- Chat section -->
    <div class="chat-card" id="sec-chat">
      <div class="chat-title">Chat 💬</div>
      <div id="cmsgs" class="cmsgs"></div>
      <div class="chat-row"><input id="cin" type="text" placeholder="Escreve algo…" maxlength="200" autocomplete="off"/><button class="btn btn-ghost btn-sm" id="chat-send">Enviar</button></div>
    </div>

    <div style="text-align:center">
      <button class="btn btn-danger btn-sm" id="leave-btn">Sair da Stream</button>
    </div>
  </div>

  <!-- Bottom nav (mobile) -->
  <nav class="bottom-nav">
    <button class="bnbtn on" id="bn-live" onclick="setTab('live')"><span class="bnicon">📺</span>A Tocar</button>
    <button class="bnbtn" id="bn-vote" onclick="setTab('vote')"><span class="bnicon">🗳️</span>Votar</button>
    <button class="bnbtn" id="bn-chat" onclick="setTab('chat')"><span class="bnicon">💬</span>Chat<div class="bnbadge" id="cbadge" style="display:none">0</div></button>
  </nav>
</div>

<div id="toast"></div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getDatabase, ref, set, get, onValue, off, remove } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

const app = initializeApp({
  apiKey:"AIzaSyA8azNy6GEgD190y_fW91ahUbKa1w5veik",
  authDomain:"aawards.firebaseapp.com",
  databaseURL:"https://aawards-default-rtdb.firebaseio.com",
  projectId:"aawards",storageBucket:"aawards.firebasestorage.app",
  messagingSenderId:"839334918366",appId:"1:839334918366:web:454a259fa3e2665b46ea4f"
});
const db = getDatabase(app);

const S={code:null,roomName:null,myId:null,myName:null,unsubs:[],nowPlaying:null,lastNpKey:null,ldata:null,ytp:null,ytReady:false,specTimer:null};
const mkId=()=>Math.random().toString(36).slice(2,10)+Date.now().toString(36);
const esc=s=>s?String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'):'';
const fmt=s=>{s=Math.floor(s||0);return Math.floor(s/60)+':'+(s%60<10?'0':'')+(s%60);};
const dbr=p=>ref(db,p);

function toast(msg,d=3000){const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),d);}
function goScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}

/* AUTO JOIN FROM URL */
window.addEventListener('DOMContentLoaded',()=>{
  const p=new URLSearchParams(location.search);
  const code=p.get('code');
  if(code){document.getElementById('aud-code').value=code.toUpperCase();}
});

/* JOIN */
document.getElementById('aud-submit').onclick=joinStream;
document.getElementById('aud-name').onkeypress=e=>{if(e.key==='Enter')document.getElementById('aud-code').focus();};
document.getElementById('aud-code').onkeypress=e=>{if(e.key==='Enter')joinStream();};

async function joinStream(){
  const name=document.getElementById('aud-name').value.trim();
  const code=document.getElementById('aud-code').value.trim().toUpperCase();
  const err=document.getElementById('aud-err');err.textContent='';
  if(!name){err.textContent='Precisas de um nick!';return;}
  if(code.length!==6){err.textContent='Código inválido!';return;}
  try{
    const snap=await get(dbr('rooms/'+code));
    if(!snap.exists()){err.textContent='Sala não encontrada!';return;}
    const myId=mkId();
    await set(dbr('rooms/'+code+'/participants/'+myId),{name,isHost:false,isAudience:true});
    Object.assign(S,{code,roomName:snap.val().name,myId,myName:name});
    // Find streamer name
    const hostId=snap.val().host;
    const hostName=(snap.val().participants&&snap.val().participants[hostId])?snap.val().participants[hostId].name:'Streamer';
    enterAudienceRoom(hostName);
  }catch(e){err.textContent='Erro: '+e.message;}
}

function enterAudienceRoom(streamerName){
  goScreen('aud-room');
  document.getElementById('at-room').textContent=S.roomName;
  document.getElementById('at-streamer').textContent='de '+streamerName;
  listenRoom();listenChat();listenReactions();listenSuggestions();
}

function listenRoom(){
  const r=dbr('rooms/'+S.code);
  onValue(r,snap=>{
    if(!snap.exists()){doLeave();return;}
    const d=snap.val();
    const np=d.nowPlaying||null;
    const key=np?(np.title+'|'+np.ytId+'|'+np.singerId):'null';
    if(key!==S.lastNpKey){S.lastNpKey=key;S.nowPlaying=np;onNewSong(np);}
    if(d.playback)applyPB(d.playback);
  });
  S.unsubs.push(()=>off(r));
}

function onNewSong(np){
  const card=document.getElementById('np-card'),idle=document.getElementById('idle');
  const yw=document.getElementById('yt-wrap'),pb=document.getElementById('pbstatus');
  if(!np){card.style.display='none';idle.style.display='block';yw.style.display='none';pb.style.display='none';destroyYT();S.ldata=null;return;}
  card.style.display='block';idle.style.display='none';
  document.getElementById('np-who').textContent='🎤 '+np.singerName;
  document.getElementById('np-title').textContent=np.title;
  document.getElementById('np-artist').textContent=np.artist;
  fetchLyrics(np.title,np.artist);
  if(np.ytId){yw.style.display='block';pb.style.display='flex';loadYT(np.ytId);}
  else{yw.style.display='none';pb.style.display='none';destroyYT();}
}

function loadYT(vid){if(S.ytReady)buildYT(vid);else window._pendYT=()=>buildYT(vid);}
function buildYT(vid){
  destroyYT();
  const wrap=document.getElementById('yt-wrap');let d=document.getElementById('ytplayer');
  if(!d){d=document.createElement('div');d.id='ytplayer';wrap.insertBefore(d,wrap.firstChild);}
  S.ytp=new YT.Player('ytplayer',{videoId:vid,playerVars:{autoplay:0,controls:0,rel:0,disablekb:1,modestbranding:1,iv_load_policy:3,playsinline:1},events:{onReady:()=>S.ytp.setVolume(80),onStateChange:e=>{if(e.data===YT.PlayerState.PLAYING)document.getElementById('sync-overlay').classList.add('gone');}}});
}
function destroyYT(){if(S.ytp){try{S.ytp.destroy()}catch{}S.ytp=null;}}

function applyPB(pb){
  if(!pb)return;
  const lag=(Date.now()-pb.ts)/1000,target=pb.position+(pb.playing?lag:0);
  document.getElementById('pbdot').classList.toggle('on',pb.playing);
  document.getElementById('pblabel').textContent=pb.playing?'▶ A tocar':'⏸ Pausado';
  document.getElementById('pbtime').textContent=fmt(target);
  if(!S.ytp)return;
  try{
    const st=S.ytp.getPlayerState(),cur=S.ytp.getCurrentTime()||0,diff=Math.abs(cur-target);
    if(pb.playing){if(diff>1.5)S.ytp.seekTo(target,true);if(st!==YT.PlayerState.PLAYING){S.ytp.seekTo(target,true);S.ytp.playVideo();}if(S.ldata?.type==='synced')hlLyric(S.ytp.getCurrentTime()||target);}
    else{if(st===YT.PlayerState.PLAYING)S.ytp.pauseVideo();if(diff>0.5)S.ytp.seekTo(target,true);if(S.ldata?.type==='synced')hlLyric(target);}
  }catch{}
}

window.onYouTubeIframeAPIReady=()=>{S.ytReady=true;if(window._pendYT){window._pendYT();window._pendYT=null;}};

async function fetchLyrics(title,artist){
  const ll=document.getElementById('lload'),ln=document.getElementById('lnone'),lv=document.getElementById('llines');
  lv.innerHTML='';ln.style.display='none';ll.style.display='flex';S.ldata=null;
  try{const r=await fetch('https://lrclib.net/api/search?track_name='+encodeURIComponent(title)+'&artist_name='+encodeURIComponent(artist));const data=await r.json();if(!data?.length)throw 0;const entry=data.find(d=>d.syncedLyrics)||data.find(d=>d.plainLyrics)||data[0];if(entry.syncedLyrics){S.ldata=parseLRC(entry.syncedLyrics);S.ldata.type='synced';}else if(entry.plainLyrics){S.ldata=parsePlain(entry.plainLyrics);S.ldata.type='plain';}else throw 0;renderLyrics();}catch{ln.style.display='block';}finally{ll.style.display='none';}
}
function parseLRC(lrc){const lines=[];lrc.split('\n').forEach(l=>{const m=l.match(/\[(\d+):(\d+\.\d+)\](.*)/);if(m)lines.push({t:+m[1]*60+ +m[2],text:m[3].trim()});});return{lines};}
function parsePlain(p){return{lines:p.split('\n').filter(l=>l.trim()).map(text=>({t:null,text}))};}
function renderLyrics(){if(!S.ldata)return;document.getElementById('llines').innerHTML=S.ldata.lines.map((l,i)=>'<div class="lyric" id="ly'+i+'">'+esc(l.text)+'</div>').join('');}
function hlLyric(t){if(!S.ldata)return;const lines=S.ldata.lines;let cur=0;for(let i=0;i<lines.length;i++)if(lines[i].t!==null&&lines[i].t<=t)cur=i;document.querySelectorAll('#llines .lyric').forEach((el,i)=>{el.classList.toggle('active',i===cur);el.classList.toggle('past',i<cur);});document.getElementById('ly'+cur)?.scrollIntoView({behavior:'smooth',block:'center'});}

/* REACTIONS */
function listenReactions(){
  const r=dbr('rooms/'+S.code+'/reactions/feed');
  let lastTs=Date.now();
  onValue(r,snap=>{if(!snap.exists())return;Object.values(snap.val()||{}).filter(i=>i.ts>lastTs-500).forEach(item=>{lastTs=item.ts;spawnReact(item.emoji);});});
  S.unsubs.push(()=>off(r));
}
function spawnReact(emoji){const feed=document.getElementById('react-feed');if(!feed)return;const el=document.createElement('span');el.className='react-float';el.textContent=emoji;el.style.left=Math.random()*80+'%';feed.appendChild(el);setTimeout(()=>el.remove(),2500);}
async function sendReaction(emoji){
  const id=mkId();
  await set(dbr('rooms/'+S.code+'/reactions/feed/'+id),{emoji,by:S.myName,ts:Date.now()});
  const snap=await get(dbr('rooms/'+S.code+'/reactions/total'));
  await set(dbr('rooms/'+S.code+'/reactions/total'),(snap.val()||0)+1);
  setTimeout(()=>remove(dbr('rooms/'+S.code+'/reactions/feed/'+id)),5000);
}
window.sendReaction=sendReaction;

/* SUGGEST & VOTE */
document.getElementById('suggest-btn').onclick=searchForSuggest;
document.getElementById('sq').onkeypress=e=>{if(e.key==='Enter')searchForSuggest();};
async function searchForSuggest(){
  const q=document.getElementById('sq').value.trim();const el=document.getElementById('sres');if(!q)return;
  el.innerHTML='<div style="color:var(--dim);font-size:.74rem">A pesquisar…</div>';
  try{const r=await fetch('https://lrclib.net/api/search?q='+encodeURIComponent(q));const data=await r.json();if(!data?.length){el.innerHTML='<div style="color:var(--dim)">Sem resultados</div>';return;}const seen=new Set();el.innerHTML='';data.filter(d=>{const k=d.trackName+'|'+d.artistName;if(seen.has(k))return false;seen.add(k);return true;}).slice(0,5).forEach(item=>{const div=document.createElement('div');div.className='ri';div.innerHTML='<div class="ri-info"><span class="ri-t">'+esc(item.trackName)+'</span><span class="ri-a">'+esc(item.artistName)+'</span></div><button class="btn btn-cyan btn-sm" style="flex-shrink:0">💡</button>';div.querySelector('button').onclick=async e=>{e.stopPropagation();await suggestSong(item.trackName,item.artistName);el.innerHTML='';document.getElementById('sq').value='';};el.appendChild(div);});}catch{el.innerHTML='<div style="color:#ff6b6b">Erro</div>';}
}
async function suggestSong(title,artist){
  const snap=await get(dbr('rooms/'+S.code+'/suggestions'));
  const existing=snap.val()||{};
  const dupe=Object.values(existing).find(s=>s.title===title&&s.artist===artist);
  if(dupe){toast('Esta música já foi sugerida! Vota nela 👇');return;}
  const sid=mkId();
  await set(dbr('rooms/'+S.code+'/suggestions/'+sid),{title,artist,suggestedBy:S.myName,votes:0,voters:{},ts:Date.now()});
  toast('Sugestão enviada! 💡 Agora vota nela!');
}

function listenSuggestions(){
  const r=dbr('rooms/'+S.code+'/suggestions');
  onValue(r,snap=>{
    const data=snap.val()||{};
    const items=Object.entries(data).sort(([,a],[,b])=>(b.votes||0)-(a.votes||0));
    const el=document.getElementById('vote-list');
    if(!items.length){el.innerHTML='<div class="v-empty">Ainda sem sugestões — sê o primeiro!</div>';return;}
    const maxV=Math.max(1,items[0][1].votes||0);
    el.innerHTML=items.slice(0,6).map(([sid,s])=>{
      const pct=Math.round(((s.votes||0)/maxV)*100);
      const myVoted=(s.voters||{})[S.myId];
      return '<div class="v-item '+(myVoted?'voted':'')+'"><div class="v-info"><div class="v-t">'+esc(s.title)+'</div><div class="v-meta">'+esc(s.artist)+(s.suggestedBy?' · por '+esc(s.suggestedBy):'')+'</div></div><div class="v-bar-wrap"><div class="v-bar"><div class="v-fill" style="width:'+pct+'%"></div></div><span class="v-count">'+(s.votes||0)+'</span></div><button class="vote-btn '+(myVoted?'voted':'')+'" data-sid="'+sid+'">'+(myVoted?'✓':'Votar')+'</button></div>';
    }).join('');
    el.querySelectorAll('.vote-btn[data-sid]').forEach(btn=>btn.onclick=()=>castVote(btn.dataset.sid));
  });
  S.unsubs.push(()=>off(r));
}
async function castVote(sid){
  const snap=await get(dbr('rooms/'+S.code+'/suggestions/'+sid+'/voters/'+S.myId));
  if(snap.exists()){toast('Já votaste nesta!');return;}
  await set(dbr('rooms/'+S.code+'/suggestions/'+sid+'/voters/'+S.myId),true);
  const vsnap=await get(dbr('rooms/'+S.code+'/suggestions/'+sid+'/votes'));
  await set(dbr('rooms/'+S.code+'/suggestions/'+sid+'/votes'),(vsnap.val()||0)+1);
  toast('Voto registado! 🗳️');
}

/* CHAT */
let unreadChat=0;
function listenChat(){
  const r=dbr('rooms/'+S.code+'/chat');
  onValue(r,snap=>{
    const msgs=snap.val()||{};const el=document.getElementById('cmsgs');el.innerHTML='';
    Object.values(msgs).sort((a,b)=>a.ts-b.ts).slice(-60).forEach(m=>{
      const d=document.createElement('div');d.className='msg'+(m.type==='sys'?' sys':'')+(m.authorId===S.myId?' mine':'');
      if(m.type==='sys')d.textContent=m.text;
      else{const cls=m.isAudience?'aud':m.isHost?'host':'singer';d.innerHTML='<span class="who '+cls+'">'+esc(m.author)+':</span>'+esc(m.text);}
      el.appendChild(d);
    });el.scrollTop=el.scrollHeight;
    if(document.getElementById('bn-chat')&&!document.getElementById('bn-chat').classList.contains('on')){unreadChat++;const b=document.getElementById('cbadge');if(b){b.textContent=unreadChat>9?'9+':unreadChat;b.style.display='flex';}}
  });
  S.unsubs.push(()=>off(r));
}
document.getElementById('chat-send').onclick=sendChat;
document.getElementById('cin').onkeypress=e=>{if(e.key==='Enter')sendChat();};
async function sendChat(){const i=document.getElementById('cin');const text=i.value.trim();if(!text)return;i.value='';await set(dbr('rooms/'+S.code+'/chat/'+mkId()),{type:'user',author:S.myName,authorId:S.myId,isAudience:true,text,ts:Date.now()});}

/* LEAVE */
document.getElementById('leave-btn').onclick=doLeave;
async function doLeave(){
  S.unsubs.forEach(fn=>{try{fn()}catch{}});S.unsubs.length=0;destroyYT();
  if(S.code&&S.myId){await remove(dbr('rooms/'+S.code+'/participants/'+S.myId));const snap=await get(dbr('rooms/'+S.code+'/participants'));if(!snap.val())await remove(dbr('rooms/'+S.code));}
  Object.assign(S,{code:null,roomName:null,myId:null,myName:null,unsubs:[],nowPlaying:null,lastNpKey:null,ldata:null,ytp:null});
  goScreen('join');toast('Saíste da stream 👋');
}

/* MOBILE TABS */
window.setTab=function(tab){
  ['live','vote','chat'].forEach(t=>document.getElementById('bn-'+t)?.classList.toggle('on',t===tab));
  if(tab==='chat'){unreadChat=0;const b=document.getElementById('cbadge');if(b)b.style.display='none';setTimeout(()=>document.getElementById('cin')?.focus(),80);}
  const scroll=document.getElementById('aud-scroll');
  if(window.innerWidth<660){
    const map={live:'np-card',vote:'sec-vote',chat:'sec-chat'};
    const target=document.getElementById(map[tab])||(tab==='live'?document.getElementById('idle'):null);
    if(target)target.scrollIntoView({behavior:'smooth',block:'start'});
  }
};
</script>
<script src="https://www.youtube.com/iframe_api" defer></script>
</body>
</html>